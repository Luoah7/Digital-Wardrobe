.search-panel {
  background: rgba(255, 250, 246, 0.86);
}

.filter-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.chip-row.compact {
  margin-top: 4rpx;
}

.chip-row {
  align-items: flex-start;
}

.garment-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.garment-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  background: rgba(255, 249, 243, 0.96);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 18rpx 30rpx rgba(120, 93, 70, 0.08);
  text-align: left;
}

.garment-preview {
  position: relative;
  min-height: 300rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-start;
  padding: 20rpx;
  overflow: hidden;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.64);
}

.garment-preview-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.garment-dot {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 999rpx;
  box-shadow: 0 0 0 6rpx rgba(255, 255, 255, 0.3);
}

.garment-type {
  position: relative;
  z-index: 1;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.88);
  font-size: 22rpx;
}

.garment-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 0 6rpx 8rpx;
}

.garment-name {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.garment-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #766e66;
  font-size: 22rpx;
}

.garment-note {
  color: var(--muted);
  font-size: 22rpx;
  line-height: 1.45;
}
