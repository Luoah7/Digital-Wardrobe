.hero-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  background:
    radial-gradient(circle at 85% 10%, rgba(219, 184, 191, 0.42), transparent 28%),
    radial-gradient(circle at 15% 15%, rgba(154, 181, 160, 0.26), transparent 25%),
    linear-gradient(180deg, rgba(255, 251, 246, 0.98) 0%, rgba(247, 237, 226, 0.96) 100%);
}

.section-card {
  padding-top: 22rpx;
}

.split-heading {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.split-overline {
  font-size: 24rpx;
  letter-spacing: 0.28em;
  color: rgba(83, 69, 64, 0.42);
  text-transform: uppercase;
}

.split-title {
  font-size: 58rpx;
  line-height: 0.98;
  font-weight: 700;
  letter-spacing: -0.05em;
  font-family: var(--font-display);
}

.weather-strip {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  color: #655a53;
  font-size: 22rpx;
}

.top-strip-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.top-strip {
  flex: 1;
  min-width: 0;
  margin-top: 2rpx;
  margin-bottom: -4rpx;
  padding: 0 6rpx;
}

.top-weather-button {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  margin-left: 0;
}

.weather-strip-side {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.hero-copy {
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 68rpx;
  line-height: 0.96;
  font-weight: 700;
  letter-spacing: -0.04em;
  margin: 6rpx 0 16rpx;
  font-family: var(--font-display);
}

.hero-desc {
  color: #675e57;
  line-height: 1.5;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(115, 95, 84, 0.08);
  color: #5e534c;
  font-size: 22rpx;
}

.hero-recommend {
  margin-top: 10rpx;
  width: calc(100% + 20rpx);
  box-sizing: border-box;
  margin-left: -10rpx;
  margin-right: -10rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 18rpx;
  padding: 22rpx 20rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(41, 31, 34, 0.88);
  color: #f8f0ea;
  text-align: left;
}

.hero-recommend-copy {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 100%;
}

.hero-chip {
  display: inline-flex;
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 244, 236, 0.9);
  font-size: 22rpx;
}

.hero-recommend-title {
  display: block;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.02;
  letter-spacing: -0.05em;
  margin-top: 8rpx;
  margin-left: 0;
  padding-left: 0;
  text-indent: 0;
  color: #fff8f2;
  font-family: var(--font-display);
}

.hero-recommend-desc {
  display: block;
  color: rgba(255, 244, 236, 0.74);
  font-size: 22rpx;
  line-height: 1.45;
  margin-top: 8rpx;
  margin-left: 0;
  padding-left: 0;
  text-indent: 0;
}

.recommend-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
}

.recommend-preview {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.recommend-piece-card {
  width: 72rpx;
  height: 92rpx;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.08);
}

.recommend-piece-image {
  width: 100%;
  height: 100%;
}

.recommend-cta {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  white-space: nowrap;
  padding: 9rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  color: rgba(255, 244, 236, 0.86);
  font-size: 20rpx;
}

.icon-invert {
  filter: brightness(0) invert(1);
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.metric-card {
  min-height: 176rpx;
  gap: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx 20rpx;
}

.metric-label,
.metric-note,
.mini-outfit-names {
  color: #766e66;
  font-size: 22rpx;
}

.metric-value {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.privilege-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: linear-gradient(160deg, rgba(57, 44, 48, 0.92) 0%, rgba(93, 74, 70, 0.9) 100%);
  color: #fff7f1;
}

.privilege-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.privilege-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.14);
}

.privilege-overline {
  color: rgba(255, 242, 236, 0.62);
}

.privilege-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fffaf4;
  font-family: var(--font-display);
}

.privilege-body {
  color: rgba(255, 242, 236, 0.74);
  line-height: 1.5;
  font-size: 24rpx;
}

.privilege-button {
  margin-top: 8rpx;
}

.quick-card {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-start;
  min-height: 236rpx;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 249, 243, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  box-shadow: 0 14rpx 26rpx rgba(120, 93, 70, 0.08);
  text-align: left;
}

.quick-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.72;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 700;
}

.quick-desc {
  color: var(--muted);
  font-size: 24rpx;
}

.story-card {
  color: var(--text);
  padding: 18rpx 22rpx;
}

.story-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  color: #816c5f;
  font-size: 22rpx;
  margin-bottom: 10rpx;
}

.story-tag.compact {
  margin-bottom: 0;
}

.story-copy {
  display: block;
  line-height: 1.55;
  font-size: 24rpx;
  margin-left: 0;
  padding-left: 0;
  text-indent: 0;
}

.rhythm-header {
  margin-bottom: 12rpx;
}

.tomorrow-strip {
  padding: 18rpx 22rpx;
}

.tomorrow-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tomorrow-title {
  font-size: 48rpx;
  line-height: 1.04;
  font-weight: 700;
  font-family: var(--font-display);
}

.tomorrow-meta {
  font-size: 22rpx;
  color: #8d8178;
  text-align: right;
}

.outfit-list {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
}

.outfit-card {
  width: 100%;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 168rpx;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 247, 0.98);
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  box-shadow: 0 12rpx 24rpx rgba(120, 93, 70, 0.08);
  text-align: left;
}

.outfit-thumb {
  position: relative;
  width: 68rpx;
  height: 82rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.94), rgba(245,235,224,0.92));
  box-shadow: 0 8rpx 18rpx rgba(120, 93, 70, 0.08);
  overflow: hidden;
}

.outfit-thumb-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.outfit-thumb-dot {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.36);
}

.outfit-thumb-row {
  display: flex;
  gap: 0;
  align-items: center;
  justify-content: flex-end;
  width: 168rpx;
  min-width: 168rpx;
}

.outfit-thumb + .outfit-thumb {
  margin-left: -18rpx;
}

.outfit-thumb.is-focus {
  background: linear-gradient(180deg, rgba(219,221,229,0.98), rgba(140,144,156,0.92));
}

.outfit-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.outfit-name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.18;
  color: #1f1a1f;
  word-break: break-word;
}

.outfit-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(117, 100, 87, 0.08);
  color: #6d6057;
  font-size: 21rpx;
  line-height: 1;
}

.outfit-piece-summary {
  display: -webkit-box;
  font-size: 24rpx;
  line-height: 1.45;
  color: #766e66;
  max-width: 100%;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.outfit-arrow {
  width: 22rpx;
  height: 22rpx;
  opacity: 0.7;
}
