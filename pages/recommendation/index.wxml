<view class="app-shell">
  <view class="page-stack">
    <view class="page-header">
      <view class="page-header-copy">
        <text class="page-overline">today's answer</text>
        <text class="page-title">今日推荐</text>
        <text class="page-subtitle">{{weatherText}}</text>
      </view>
      <button class="page-icon-button" bindtap="goBack">
        <image class="icon-md" src="{{icons.cloudRain}}" mode="aspectFit"></image>
      </button>
    </view>

    <view class="card main-card" wx:if="{{recommendation}}">
      <view class="main-weather">
        <view>
          <text class="main-city">{{weatherText}}</text>
          <text class="section-tip">默认通勤模式</text>
        </view>
        <image class="icon-md" src="{{icons.cloudRain}}" mode="aspectFit"></image>
      </view>
      <text class="main-title">{{recommendation.label}}</text>
      <text class="main-note">{{recommendation.reason}}</text>
      <view class="reason-badges">
        <view class="reason-badge">
          <image class="icon-xs" src="{{icons.heart}}" mode="aspectFit"></image>
          <text>避开最近穿过</text>
        </view>
        <view class="reason-badge">
          <image class="icon-xs" src="{{icons.umbrella}}" mode="aspectFit"></image>
          <text>兼顾轻雨</text>
        </view>
      </view>
    </view>

    <view class="card" wx:if="{{pieces.length}}">
      <view class="section-header">
        <text class="section-title">这一套由这些单品组成</text>
      </view>
      <view class="piece-list">
        <block wx:for="{{pieces}}" wx:key="id">
          <view class="piece-row">
            <image class="piece-image" src="{{item.placeholderImage}}" mode="aspectFit"></image>
            <view class="piece-copy">
              <text class="piece-name">{{item.name}}</text>
              <text class="piece-meta">{{item.detailLine}}</text>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="card soft" wx:if="{{recommendation}}">
      <text class="page-overline">why this one</text>
      <text>{{recommendation.note}}</text>
    </view>

    <view class="card" wx:if="{{alternatives.length}}">
      <view class="section-header">
        <text class="section-title">替代选项</text>
      </view>
      <view class="alt-list">
        <block wx:for="{{alternatives}}" wx:key="id">
          <view class="alt-card">
            <view class="alt-head">
              <text class="alt-name">{{item.name}}</text>
              <text class="section-tip">{{item.label}}</text>
            </view>
            <view class="mini-alt-stack">
              <block wx:for="{{item.previewPieces}}" wx:key="id">
                <image class="mini-alt-image" src="{{item.placeholderImage}}" mode="aspectFit"></image>
              </block>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="action-stack">
      <button class="primary-button" bindtap="rotateRecommendation">换一套</button>
      <button class="secondary-button" bindtap="addToTomorrow">加入明天计划</button>
      <button class="secondary-button" bindtap="markWorn">标记今天就穿这套</button>
    </view>
  </view>
</view>
