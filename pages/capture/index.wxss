.capture-choice-list,
.draft-meta {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.capture-choice {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.76);
  text-align: left;
}

.capture-choice-icon {
  width: 36rpx;
  height: 36rpx;
}

.capture-choice-title {
  font-size: 30rpx;
  font-weight: 700;
}

.capture-choice-desc {
  color: var(--muted);
  font-size: 24rpx;
}

.processing-card,
.confirm-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.processing-bar {
  width: 100%;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(128, 149, 123, 0.12);
  overflow: hidden;
}

.processing-bar-fill {
  width: 72%;
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7f947b 0%, #5f745c 100%);
}

.draft-preview {
  min-height: 280rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.draft-preview-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.preview-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
}

.draft-preview-tag {
  position: relative;
  z-index: 1;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.88);
}

.draft-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
}
