<view class="app-shell">
  <view class="page-stack">
    <view class="page-header">
      <view class="page-header-copy">
        <text class="page-overline">capture flow</text>
        <text class="page-title">拍照入橱</text>
        <text class="page-subtitle">拍照或选图，确认信息后保存入橱。</text>
      </view>
      <button class="page-icon-button" bindtap="goBack">
        <image class="icon-md" src="{{icons.camera}}" mode="aspectFit"></image>
      </button>
    </view>

    <view class="card soft" wx:if="{{limitReached}}">
      <text class="section-title">免费额度已满</text>
      <text class="section-tip">非特权用户最多可管理 10 件衣物，继续入橱前需要后台管理员开通特权。</text>
      <button class="secondary-button" bindtap="goBack">先回首页</button>
    </view>

    <block wx:elif="{{step === 'capture'}}">
      <view class="card">
        <view class="section-header">
          <text class="section-title">选择入橱方式</text>
          <text class="section-tip">当前剩余 {{remainingSlots}} 个免费名额</text>
        </view>
        <view class="capture-choice-list">
          <view class="capture-choice" data-source="camera" bindtap="chooseSource">
            <image class="capture-choice-icon" src="{{icons.camera}}" mode="aspectFit"></image>
            <text class="capture-choice-title">立即拍照</text>
            <text class="capture-choice-desc">更适合新买入的衣物，识别流程更快。</text>
          </view>
          <view class="capture-choice" data-source="album" bindtap="chooseSource">
            <image class="capture-choice-icon" src="{{icons.album}}" mode="aspectFit"></image>
            <text class="capture-choice-title">从相册导入</text>
            <text class="capture-choice-desc">适合补录以前拍过的单品图片。</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:elif="{{uploading}}">
      <view class="card processing-card">
        <text class="section-title">正在上传图片...</text>
        <view class="draft-preview" wx:if="{{draft && draft.imageUrl}}">
          <image class="draft-preview-image" src="{{draft.imageUrl}}" mode="aspectFit"></image>
        </view>
        <view class="processing-bar">
          <view class="processing-bar-fill"></view>
        </view>
      </view>
    </block>

    <block wx:elif="{{step === 'confirm' && draft}}">
      <!-- Image preview -->
      <view class="card">
        <view class="draft-preview" style="background: linear-gradient(140deg, rgba(255,255,255,0.98), {{draft.accent}}22);">
          <image class="draft-preview-image" src="{{draft.displayImage || draft.imageUrl}}" mode="aspectFit"></image>
          <view class="piece-dot preview-dot" style="background: {{draft.accent}};"></view>
        </view>
      </view>

      <!-- Name -->
      <view class="card">
        <view class="section-header">
          <text class="section-title">衣物名称</text>
        </view>
        <input class="name-input" value="{{draft.name}}" bindinput="onNameInput" placeholder="给这件衣服起个名字" />
      </view>

      <!-- Type selector -->
      <view class="card">
        <view class="section-header">
          <text class="section-title">衣物类型</text>
          <text class="section-tip">选择最匹配的分类</text>
        </view>
        <view class="option-grid">
          <block wx:for="{{typeOptions}}" wx:key="value">
            <view class="option-chip {{draft.type === item.value ? 'is-active' : ''}}" data-value="{{item.value}}" bindtap="selectType">
              <text>{{item.label}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- Color selector -->
      <view class="card">
        <view class="section-header">
          <text class="section-title">颜色</text>
        </view>
        <view class="color-grid">
          <block wx:for="{{colorOptions}}" wx:key="value">
            <view class="color-chip {{draft.color === item.value ? 'is-active' : ''}}" data-value="{{item.value}}" data-hex="{{item.hex}}" bindtap="selectColor">
              <view class="color-dot" style="background: {{item.hex}};"></view>
              <text>{{item.value}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- Season selector -->
      <view class="card">
        <view class="section-header">
          <text class="section-title">可穿季节</text>
          <text class="section-tip">可多选</text>
        </view>
        <view class="option-grid">
          <block wx:for="{{seasonOptions}}" wx:key="value">
            <view class="option-chip {{item.active ? 'is-active' : ''}}" data-value="{{item.value}}" bindtap="toggleSeason">
              <text>{{item.value}}</text>
            </view>
          </block>
        </view>
      </view>

      <!-- Warmth level -->
      <view class="card">
        <view class="section-header">
          <text class="section-title">厚薄度</text>
        </view>
        <view class="warmth-row">
          <view class="warmth-bar">
            <view class="warmth-fill" style="width: {{draft.warmthLevel * 25}}%;"></view>
          </view>
          <button class="chip active" bindtap="increaseWarmth">Lv.{{draft.warmthLevel}}</button>
        </view>
        <text class="section-tip">1=薄 → 4=厚，点击按钮切换</text>
      </view>

      <!-- Save -->
      <button class="primary-button" bindtap="saveCapture">保存入橱</button>
    </block>
  </view>
</view>
