<view class="app-shell">
  <view class="page-stack">
    <view class="page-header">
      <view class="page-header-copy">
        <text class="page-overline">garment detail</text>
        <text class="page-title">{{garment ? garment.name : '单品详情'}}</text>
        <text class="page-subtitle" wx:if="{{garment}}">{{garment.type}} · {{garment.color}} · {{garment.subType}}</text>
      </view>
      <button class="page-icon-button" bindtap="goBack">
        <image class="icon-md" src="{{icons.closet}}" mode="aspectFit"></image>
      </button>
    </view>

    <!-- Loading state -->
    <view class="card" wx:if="{{loading}}">
      <text class="section-tip">加载中...</text>
    </view>

    <!-- Error state -->
    <view class="card" wx:elif="{{error}}">
      <text class="section-title">{{error}}</text>
      <text class="section-tip">请检查网络连接后重试。</text>
      <button class="secondary-button" bindtap="refreshPage">重试</button>
    </view>

    <!-- View mode -->
    <block wx:if="{{!editing}}">
      <view class="card" wx:if="{{garment}}">
        <view class="detail-preview" style="background: linear-gradient(140deg, rgba(255,255,255,0.98), {{garment.accent}}22);">
          <image class="detail-preview-image" src="{{garment.displayImage}}" mode="aspectFit"></image>
          <view class="piece-dot preview-dot" style="background: {{garment.accent}};"></view>
          <text class="detail-preview-tag">{{garment.scene}} · {{garment.texture}}</text>
        </view>
        <view class="detail-grid">
          <view class="detail-row">
            <text>季节</text>
            <text>{{garment.seasonText}}</text>
          </view>
          <view class="detail-row">
            <text>厚薄度</text>
            <text>Lv.{{garment.warmthLevel}}</text>
          </view>
          <view class="detail-row">
            <text>最近穿着</text>
            <text>{{garment.lastWornAt}}</text>
          </view>
        </view>
      </view>

      <view class="card" wx:if="{{relatedOutfits.length}}">
        <view class="section-header">
          <text class="section-title">关联搭配</text>
        </view>
        <view class="related-list">
          <block wx:for="{{relatedOutfits}}" wx:key="id">
            <view class="related-item">
              <text class="related-name">{{item.name}}</text>
              <text class="section-tip">{{item.label}}</text>
            </view>
          </block>
        </view>
      </view>

      <button class="primary-button" bindtap="goStudio">加入当前搭配</button>
      <button class="secondary-button" bindtap="markTodayWorn">标记今天穿过</button>
      <button class="secondary-button" bindtap="startEdit">编辑信息</button>
      <button class="danger-button" bindtap="confirmDelete">删除衣物</button>
    </block>

    <!-- Edit mode -->
    <block wx:if="{{editing && editDraft}}">
      <view class="card">
        <text class="section-title">编辑衣物信息</text>
        <view class="draft-meta">
          <view class="draft-row">
            <text>名称</text>
            <input class="draft-input" value="{{editDraft.name}}" bindinput="onEditNameInput" placeholder="输入名称" />
          </view>
          <view class="draft-row">
            <text>类型</text>
            <button class="chip active" bindtap="cycleEditType">{{editDraft.type}}</button>
          </view>
          <view class="draft-row">
            <text>颜色</text>
            <button class="chip active" bindtap="cycleEditColor">{{editDraft.color}}</button>
          </view>
          <view class="draft-row">
            <text>厚薄度</text>
            <button class="chip active" bindtap="increaseEditWarmth">Lv.{{editDraft.warmthLevel}}</button>
          </view>
        </view>
      </view>
      <button class="primary-button" bindtap="saveEdit">保存修改</button>
      <button class="secondary-button" bindtap="cancelEdit">取消</button>
    </block>
  </view>
</view>
