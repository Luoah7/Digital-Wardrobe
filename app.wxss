page {
  --bg: #f4ede3;
  --bg-deep: #ebe0d2;
  --panel: rgba(255, 251, 246, 0.88);
  --panel-strong: rgba(255, 249, 242, 0.96);
  --text: #29252a;
  --muted: #766c66;
  --line: rgba(65, 50, 38, 0.08);
  --sage: #91a795;
  --sage-strong: #6d8772;
  --sage-soft: rgba(145, 167, 149, 0.18);
  --pink: #d9b8be;
  --pink-soft: rgba(217, 184, 190, 0.18);
  --warning: #9c5d6b;
  --shadow: 0 26rpx 60rpx rgba(120, 93, 70, 0.16);
  --font-display: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", "Times New Roman", serif;
  --font-body: "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  min-height: 100%;
  background:
    radial-gradient(circle at 18% 10%, rgba(232, 205, 186, 0.78), transparent 28%),
    radial-gradient(circle at 82% 16%, rgba(206, 225, 212, 0.7), transparent 25%),
    radial-gradient(circle at 52% 84%, rgba(233, 193, 201, 0.55), transparent 30%),
    linear-gradient(180deg, #fbf6ef 0%, #f2e5d8 52%, #efe2d5 100%);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
  font-family: var(--font-body);
}

view,
text,
button,
input,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: inherit;
  width: auto;
  text-align: inherit;
}

button::after {
  border: 0;
}

.app-shell {
  min-height: 100vh;
  padding: 22rpx 24rpx 188rpx;
  position: relative;
}

.app-shell::before {
  content: "";
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1px, transparent 1px);
  background-size: 32rpx 32rpx;
  opacity: 0.18;
  pointer-events: none;
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.page-header {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  width: 100%;
}

.page-header-copy {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
  gap: 8rpx;
}

.page-overline {
  display: block;
  font-size: 22rpx;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: rgba(83, 69, 64, 0.48);
}

.page-title {
  display: block;
  font-size: 62rpx;
  line-height: 0.98;
  font-weight: 700;
  letter-spacing: -0.04em;
  font-family: var(--font-display);
}

.page-subtitle {
  color: #675e57;
  font-size: 26rpx;
}

.page-icon-button {
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 76rpx;
  margin-left: auto;
  align-self: flex-start;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(91, 71, 59, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(111, 83, 65, 0.08);
  font-size: 34rpx;
}

.card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: var(--panel);
  box-shadow: var(--shadow);
  border: 2rpx solid rgba(255, 255, 255, 0.74);
}

.card.soft {
  background: linear-gradient(180deg, rgba(255, 248, 250, 0.95) 0%, rgba(248, 231, 236, 0.92) 100%);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.section-header.tight {
  align-items: center;
}

.section-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: -0.04em;
  font-family: var(--font-display);
}

.section-tip {
  font-size: 24rpx;
  color: #766e66;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  min-width: 96rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(117, 101, 93, 0.1);
  color: #5d554e;
  font-size: 24rpx;
  text-align: center;
}

.hero-chip {
  display: inline-flex;
  width: fit-content;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(145, 167, 149, 0.18);
  border: 2rpx solid rgba(109, 135, 114, 0.28);
  color: #50705a;
  font-size: 22rpx;
}

.chip.active {
  background: rgba(145, 167, 149, 0.18);
  border-color: rgba(109, 135, 114, 0.28);
  color: #50705a;
}

.chip.pale.active {
  background: rgba(245, 247, 242, 0.8);
  border-color: rgba(109, 135, 114, 0.28);
}

.chip.pale {
  background: rgba(245, 247, 242, 0.8);
}

.primary-button,
.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  min-height: 88rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button {
  color: #fffdf9;
  background: linear-gradient(135deg, var(--sage-strong) 0%, #809785 100%);
  box-shadow: 0 18rpx 30rpx rgba(109, 135, 114, 0.3);
}

.secondary-button {
  color: #51463f;
  background: rgba(255, 249, 243, 0.96);
  border: 2rpx solid rgba(120, 98, 83, 0.1);
  box-shadow: 0 12rpx 24rpx rgba(120, 93, 70, 0.08);
}

.grid-two {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.text-button {
  color: var(--sage-strong);
  font-size: 26rpx;
}

.input-shell {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 0 20rpx;
  min-height: 88rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  color: #6d645d;
}

.input-shell input {
  flex: 1;
  min-width: 0;
  color: #3a2f35;
}

.empty-state {
  padding: 60rpx 28rpx;
  border-radius: 28rpx;
  text-align: center;
  color: var(--muted);
  background: rgba(255, 255, 255, 0.55);
}

.icon-xxs,
.icon-xs,
.icon-sm,
.icon-md,
.icon-lg {
  display: block;
  flex: 0 0 auto;
}

.icon-xxs { width: 20rpx; height: 20rpx; }
.icon-xs { width: 24rpx; height: 24rpx; }
.icon-sm { width: 28rpx; height: 28rpx; }
.icon-md { width: 34rpx; height: 34rpx; }
.icon-lg { width: 42rpx; height: 42rpx; }

.garment-image {
  display: block;
  width: 100%;
  height: 100%;
}

.piece-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
}
